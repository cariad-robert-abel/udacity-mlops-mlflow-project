name: test-regression-model
conda_env: conda.yml

entry_points:
  main:
    parameters:
      mlflow-model:
        description: An MLflow serialized model
        type: string
      test-dataset:
        description: The test artifact
        type: string

    command: >-
      python run.py
      --mlflow-model {mlflow-model}
      --test-dataset {test-dataset}
