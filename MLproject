name: nyc-airbnb
conda_env: conda.yml

entry_points:
  main:
    parameters:
      steps:
        description: Comma-separated list of steps to execute (useful for debugging)
        type: string
        default: all
      hydra-options:
        description: Other configuration parameters to override
        type: string
        default: ''

    command: >-
      set H={hydra-options} & call python main.py %H:"=% main.steps={steps}
